---
const { title, image } = Astro.props;
---
<div class="relative group cursor-pointer overflow-hidden h-[120px] md:h-[450px]">
  <img src={image} alt={title} class="w-full h-full object-cover transition duration-300 group-hover:scale-110" />
  
  <div class="absolute inset-0 bg-gradient-to-r md:bg-gradient-to-t from-black/70 to-transparent group-hover:bg-white/70 group-hover:from-white/70 transition-all duration-300"></div>
  
  <h3 class="absolute bottom-4 left-6 md:bottom-8 md:left-8 text-white text-2xl md:text-3xl w-32 group-hover:text-black transition-colors duration-300">
    {title}
  </h3>
</div>